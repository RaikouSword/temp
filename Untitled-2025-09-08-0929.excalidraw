      "seed": 296950363,
      "version": 132,
      "versionNonce": 944220699,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771499433574,
      "link": null,
      "locked": false,
      "text": "finding the value of k is crucial for kmeans clustering.the quality of\nclustering is measured using sse.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "finding the value of k is crucial for kmeans clustering.the quality of\nclustering is measured using sse.",
      "autoResize": true,
      "lineHeight": 1.25
    },
