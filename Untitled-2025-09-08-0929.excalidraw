    {
      "id": "9dT4FPuMesGg68HUJPmKl",
      "type": "text",
      "x": 316,
      "y": 1061,
      "width": 554.3794555664062,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
