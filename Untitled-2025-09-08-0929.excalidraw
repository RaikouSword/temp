      "isDeleted": false,
      "boundElements": null,
      "updated": 1771503473658,
      "link": null,
      "locked": false,
      "text": "KMeans\n    Centroid = Mean\n    Sensitive to outliers\n    Fast",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "KMeans\n    Centroid = Mean\n    Sensitive to outliers\n    Fast",
      "autoResize": true,
      "lineHeight": 1.25
    },
